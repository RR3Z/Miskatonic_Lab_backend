{
  "scripts": {
    "migrate:down": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 down",
    "migrate:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 up",
    "migrate:up:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 up-all",
    "migrate:version": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 version",
    "sqlc:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sqlc.ps1 generate",
    "sqlc:version": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sqlc.ps1 version",
    "test:pretty": "gotestsum --format testname -- ./tests/...",
    "test:e2e": "powershell -NoProfile -Command \"$env:E2E_TESTS='1'; go test ./tests/e2e -v\"",
    "test:migrations": "powershell -NoProfile -Command \"$env:MIGRATION_SMOKE_TESTS='1'; go test ./tests/migrations -v\"",
    "test:all": "powershell -NoProfile -Command \"go test ./...; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $env:CLERK_INTEGRATION_TESTS='1'; go test ./tests/user/integration -v; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $env:E2E_TESTS='1'; go test ./tests/e2e -v; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $env:MIGRATION_SMOKE_TESTS='1'; go test ./tests/migrations -v\"",
    "test:clerk": "powershell -NoProfile -Command \"$env:CLERK_INTEGRATION_TESTS='1'; go test ./tests/user/integration -v\"",
    "user:create": "go run ./cmd/create-user"
  }
}
