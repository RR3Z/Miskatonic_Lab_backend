{
  "scripts": {
    "dev": "npm run migrate:up:all && go run ./cmd",
    "build": "go build -o ./bin/miskatonic-lab-backend.exe ./cmd",
    "start": ".\\bin\\miskatonic-lab-backend.exe",
    "migrate:down": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 down",
    "migrate:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 up",
    "migrate:up:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 up-all",
    "migrate:version": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 version",
    "sqlc:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sqlc.ps1 generate",
    "sqlc:version": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sqlc.ps1 version",
    "test:pretty": "gotestsum --format testname -- ./tests/...",
    "test:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 setup",
    "test:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 local",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 e2e",
    "test:clerk": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 clerk",
    "test:migrations": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 migrations",
    "test:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test.ps1 all"
  }
}
