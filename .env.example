# Runtime
PORT=8000
PUBLIC_BACKEND_URL=http://localhost:8000
PORTRAIT_STORAGE_DIR=./uploads/portraits

# Runtime PostgreSQL or Supabase. DATABASE_URL takes precedence over POSTGRES_*.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=miskatonic_user
POSTGRES_PASSWORD=miskatonic_password
POSTGRES_DB=miskatonic_lab
POSTGRES_SSLMODE=disable

# Clerk runtime
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local disposable databases used by every test command.
# Both URLs must point to localhost or loopback. The smoke database is dropped
# and recreated by the runner, so its name must end with _migration_smoke_test.
TEST_DATABASE_URL=postgres://miskatonic_user:miskatonic_password@localhost:5433/miskatonic_lab_test?sslmode=disable
MIGRATION_SMOKE_DATABASE_URL=postgres://miskatonic_user:miskatonic_password@localhost:5433/miskatonic_lab_migration_smoke_test?sslmode=disable

# Existing users in the Clerk development instance. Passwords and static JWTs
# are intentionally not used: live E2E creates temporary Clerk sessions.
E2E_TEST1_MAIL=test1@example.com
E2E_TEST2_MAIL=test2@example.com

# `npm run test:setup` downloads Dev Tunnel if necessary, requests login, then
# creates these values automatically. Copy its printed webhook URL into Clerk
# Dashboard once as <CLERK_WEBHOOK_PUBLIC_URL>/webhooks/clerk/user.
TEST_BACKEND_PORT=8001
DEVTUNNEL_TUNNEL_ID=
CLERK_WEBHOOK_PUBLIC_URL=

# Optional real-webhook delivery timeout. Defaults to 120s when omitted.
# CLERK_WEBHOOK_WAIT_TIMEOUT=120s
