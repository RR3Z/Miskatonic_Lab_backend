# Порт локального Go HTTP API.
PORT=8000

# Полный URL подключения к PostgreSQL/Supabase.
# Если задан, имеет приоритет над всеми POSTGRES_*.
# Для Supabase использовать Direct connection или Session pooler с sslmode=require.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Хост PostgreSQL, используется только когда DATABASE_URL не задан.
POSTGRES_HOST=localhost

# Порт PostgreSQL, используется только когда DATABASE_URL не задан.
POSTGRES_PORT=5432

# Пользователь PostgreSQL, используется только когда DATABASE_URL не задан.
POSTGRES_USER=miskatonic_user

# Пароль PostgreSQL, используется только когда DATABASE_URL не задан.
POSTGRES_PASSWORD=miskatonic_password

# Имя базы PostgreSQL, используется только когда DATABASE_URL не задан.
POSTGRES_DB=miskatonic_lab

# Режим TLS PostgreSQL: disable для локальной DB, require для Supabase.
POSTGRES_SSLMODE=disable

# Секретный backend-ключ Clerk instance для проверки session JWT.
# Должен соответствовать frontend publishable key и начинаться с sk_test_ или sk_live_.
CLERK_SECRET_KEY=sk_test_replace_me

# Разрешённые frontend origins из JWT claim azp, через запятую и со схемой.
# Указывать frontend, который получает Clerk token; backend API origin сюда не входит.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Секрет подписи Clerk webhook endpoint; берётся отдельно в настройках webhook.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# Разрешённые browser origins для CORS, через запятую и со схемой.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Тестовая PostgreSQL DB. Тесты принимают только loopback-хост и имя базы с суффиксом _test.
TEST_DATABASE_URL=postgres://miskatonic_user:miskatonic_password@localhost:5433/miskatonic_lab_test?sslmode=disable

# Базовый адрес уже запущенного backend для opt-in E2E-тестов.
# E2E_BASE_URL=http://localhost:8000

# Реальный Clerk session token основного E2E-пользователя: raw JWT или Bearer <jwt>.
# E2E_AUTH_TOKEN=

# Необязательный Clerk session token второго пользователя для multi-user E2E.
# E2E_SECOND_AUTH_TOKEN=

# URL отдельной одноразовой DB для destructive migration rollback smoke-теста.
# MIGRATION_SMOKE_DATABASE_URL=

# Локальный backend URL для preflight Clerk integration-тестов webhook.
# CLERK_LOCAL_BACKEND_URL=http://localhost:8000

# Максимальное ожидание доставки Clerk webhook в integration-тестах.
# CLERK_WEBHOOK_WAIT_TIMEOUT=120s
