# Port for the local Go HTTP API.
PORT=8000

# Public URL used in uploaded character portrait links.
PUBLIC_BACKEND_URL=http://localhost:8000

# Local directory for backend-owned character portrait files.
PORTRAIT_STORAGE_DIR=./uploads/portraits

# Full PostgreSQL or Supabase connection URL.
# When set, this value takes precedence over all POSTGRES_* variables.
# For Supabase, use a direct connection or session pooler with sslmode=require.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# PostgreSQL host used when DATABASE_URL is not set.
POSTGRES_HOST=localhost

# PostgreSQL port used when DATABASE_URL is not set.
POSTGRES_PORT=5432

# PostgreSQL user used when DATABASE_URL is not set.
POSTGRES_USER=miskatonic_user

# PostgreSQL password used when DATABASE_URL is not set.
POSTGRES_PASSWORD=miskatonic_password

# PostgreSQL database name used when DATABASE_URL is not set.
POSTGRES_DB=miskatonic_lab

# PostgreSQL TLS mode: use disable locally and require for Supabase.
POSTGRES_SSLMODE=disable

# Clerk backend secret key used to verify session JWTs.
# It must match the frontend publishable key and start with sk_test_ or sk_live_.
CLERK_SECRET_KEY=sk_test_replace_me

# Comma-separated frontend origins allowed by the JWT azp claim, including schemes.
# Include the frontend that obtains Clerk tokens, not the backend API origin.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Signing secret configured separately for the Clerk webhook endpoint.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# Comma-separated browser origins allowed by CORS, including schemes.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL test database. Tests require a loopback host and a database name ending in _test.
TEST_DATABASE_URL=postgres://miskatonic_user:miskatonic_password@localhost:5433/miskatonic_lab_test?sslmode=disable

# Base URL of an already running backend used by opt-in E2E tests.
# E2E_BASE_URL=http://localhost:8000

# Real Clerk session token for the primary E2E user, as a raw JWT or Bearer <jwt>.
# E2E_AUTH_TOKEN=

# Optional Clerk session token for a second user in multi-user E2E tests.
# E2E_SECOND_AUTH_TOKEN=

# URL of a separate disposable database used by the destructive migration rollback smoke test.
# MIGRATION_SMOKE_DATABASE_URL=

# Local backend URL used by Clerk webhook integration test preflight checks.
# CLERK_LOCAL_BACKEND_URL=http://localhost:8000

# Maximum wait time for Clerk webhook delivery in integration tests.
# CLERK_WEBHOOK_WAIT_TIMEOUT=120s
