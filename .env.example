PORT=8000

# Supabase/Postgres connection. If DATABASE_URL is set, it takes precedence over POSTGRES_*.
# Use a Direct connection or Session pooler URL with sslmode=require.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=miskatonic_user
POSTGRES_PASSWORD=miskatonic_password
POSTGRES_DB=miskatonic_lab
POSTGRES_SSLMODE=disable

CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional test-only values:
# Database tests only accept localhost/loopback and a database ending with _test.
TEST_DATABASE_URL=postgres://miskatonic_user:miskatonic_password@localhost:5433/miskatonic_lab_test?sslmode=disable
